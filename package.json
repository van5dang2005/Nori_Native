{
  "name": "nori",
  "main": "expo-router/entry",
  "version": "1.0.16",
  "scripts": {
    "start": "env-cmd -f .env.development expo start --port 3000",
    "start:beta": "env-cmd -f .env.beta expo start --port 3000",
    "start:prod": "env-cmd -f .env.production expo start --port 3000",
    "android": "env-cmd -f .env.development expo run:android",
    "android:beta": "env-cmd -f .env.beta expo run:android",
    "android:prod": "env-cmd -f .env.production expo run:android",
    "ios": "env-cmd -f .env.development expo run:ios",
    "ios:beta": "env-cmd -f .env.beta expo run:ios",
    "ios:prod": "env-cmd -f .env.production expo run:ios",
    "web": "env-cmd -f .env.development expo start --web --port 3000",
    "build:web": "env-cmd -f .env.production expo export --platform web",
    "build:android": "env-cmd -f .env.development eas build -p android --profile development --local",
    "build:android:beta": "env-cmd -f .env.beta eas build -p android --profile preview --local",
    "build:android:prod": "env-cmd -f .env.production eas build -p android --profile production --local",
    "build:ios": "env-cmd -f .env.development eas build -p ios --profile development --local",
    "build:ios:beta": "env-cmd -f .env.beta eas build -p ios --profile preview --local",
    "build:ios:prod": "env-cmd -f .env.production eas build -p ios --profile production --local",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@google/genai": "^1.44.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-picker/picker": "2.11.1",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "eas-cli": "^18.3.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.577.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-dotenv": "^3.4.11",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "env-cmd": "^10.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
